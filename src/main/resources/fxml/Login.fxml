<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="12" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.omnitask.LoginController"
      prefWidth="360" prefHeight="400">

    <Label text="OmniTask Login" style="-fx-font-size:22;-fx-font-weight:bold;"/>

    <Label text="Username"/>
    <TextField fx:id="signin" promptText="Enter username"/>

    <Label text="Password"/>
    <PasswordField fx:id="pass" promptText="Enter password"/>

    <Button text="Login" onAction="#login" prefWidth="200"/>

    <Hyperlink text="Forgot Password?" onAction="#goForgotPassword"/>

    <HBox alignment="CENTER" spacing="6">
        <Label text="New here?"/>
        <Hyperlink text="Register" onAction="#goRegister"/>
    </HBox>

</VBox>
