<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.omnitask.TaskViewController"
            prefWidth="800" prefHeight="550">

    <!-- LEFT: Task list -->
    <left>
        <VBox spacing="8" style="-fx-padding:10;" prefWidth="200">
            <Label text="My Tasks" style="-fx-font-size:16;-fx-font-weight:bold;"/>
            <ListView fx:id="taskListView" prefHeight="450" onMouseClicked="#onTaskSelected"/>
        </VBox>
    </left>

    <!-- CENTER: Title + Text area -->
    <center>
        <VBox spacing="10" style="-fx-padding:15;" prefWidth="360">
            <Label text="Task Title"/>
            <TextField fx:id="titleField" promptText="Enter task title..."/>
            <Label text="Task Details"/>
            <TextArea fx:id="textArea" promptText="Enter task details..." prefHeight="300" wrapText="true"/>
        </VBox>
    </center>

    <!-- RIGHT: Buttons -->
    <right>
        <VBox spacing="12" style="-fx-padding:15;" prefWidth="160" alignment="TOP_CENTER">
            <Button text="Save Task" onAction="#saveTask" prefWidth="140"/>
            <Button text="Delete Task" onAction="#deleteTask" prefWidth="140"/>
            <Button text="Logout" onAction="#logout" prefWidth="140"/>
        </VBox>
    </right>

    <!-- BOTTOM: Username + Clock -->
    <bottom>
        <HBox spacing="20" style="-fx-padding:8;-fx-border-color:#cccccc;-fx-border-width:1 0 0 0;">
            <Label fx:id="usernameLabel" text="User: "/>
            <Label fx:id="clockLabel" text="00:00:00"/>
        </HBox>
    </bottom>

</BorderPane>
