<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.omnitask.RegisterController"
      prefWidth="400" prefHeight="520">

    <Label text="Create Account" style="-fx-font-size:20;-fx-font-weight:bold;"/>

    <Label text="Username"/>
    <TextField fx:id="usernameField" promptText="Choose a username"/>

    <Label text="Password"/>
    <PasswordField fx:id="passwordField" promptText="Choose a password"/>

    <Label text="Confirm Password"/>
    <PasswordField fx:id="confirmField" promptText="Confirm password"/>

    <Label text="Choose a Password Hint"/>
    <!-- ScrollPane wrapping a ListView for hint selection -->
    <ListView fx:id="hintList" prefHeight="120"/>

    <Label text="Your Answer (e.g. favourite movie name)"/>
    <TextField fx:id="favAnswerField" promptText="Type your answer"/>

    <Button text="Register" onAction="#register" prefWidth="200"/>
    <Hyperlink text="Back to Login" onAction="#goLogin"/>

</VBox>
